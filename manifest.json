{
  "manifest_version": 2,
  "name": "productWatcher",
  "version": "0.4",
  "description": "opens products in new tabs with provided sale name or category. copies requried data to clipboard for easier pasting into excel. add blue border if product is vendored by emag, yellow if make is oem.",
  "icons": {
    "48": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.emag.hu/*",
        "*://*.arukereso.hu/*"
      ],
      "js": [
        "main.js"
      ]
    }
  ],
  "permissions": [
    "*://www.emag.hu/*",
    "*://*.arukereso.hu/*"
  ],
  "browser_specific_settings": {
      "gecko": {
          "update_url": "https://wargesz.chickenkiller.com/archives/product-watcher.json",
          "data_collection_permissions": {
              "required": ["websiteContent"],
              "optional": []
          },
          "id": "productWatcher@wargesz.chickenkiller.com"
      }
  }
}
